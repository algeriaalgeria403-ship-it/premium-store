{% stylesheet %}
  .reviews-section {
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .reviews-rating {
    text-align: center;
    margin: 2rem 0;
  }

  .rating-circle {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(0, 153, 255, 0.1));
    border: 2px solid #00d4ff;
    margin-bottom: 1rem;
  }

  .reviews-carousel {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .review-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .review-card:hover {
    background: rgba(0, 212, 255, 0.1);
    border-color: #00d4ff;
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .review-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00d4ff, #0099ff);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    color: #0f172a;
  }

  .review-stars {
    color: #ff006e;
    margin-bottom: 0.5rem;
  }
{% endstylesheet %}

<section class="reviews-section" id="reviews">
  <div class="section-header">
    <h2>{{ section.settings.title }}</h2>
    <p>{{ section.settings.subtitle }}</p>
  </div>

  <div class="reviews-rating">
    <div class="rating-circle">
      <div style="font-size: 2.5rem; font-weight: bold; color: #00d4ff;">4.9</div>
      <div style="font-size: 1rem; color: #e0e0e0; opacity: 0.7;">/5</div>
    </div>
    <div class="review-stars" style="font-size: 2rem; letter-spacing: 0.2rem;">★★★★★</div>
    <p>Based on 2,500+ verified reviews</p>
  </div>

  <div class="reviews-carousel">
    {% for review in section.blocks %}
      <div class="review-card">
        <div class="review-header">
          <div class="review-avatar">{{ review.settings.name | slice: 0 }}</div>
          <div>
            <h4>{{ review.settings.name }}</h4>
            <p style="font-size: 0.875rem; opacity: 0.7;">{{ review.settings.product }}</p>
          </div>
        </div>
        <div class="review-stars">★★★★★</div>
        <p>{{ review.settings.text }}</p>
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "What our customers say about us"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name",
          "default": "John Doe"
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product Purchased",
          "default": "Netflix Premium"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "Excellent service! Got my account in 5 minutes."
        }
      ]
    }
  ]
}
{% endschema %}